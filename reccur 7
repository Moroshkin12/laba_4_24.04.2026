#Написать рекурсивную функцию для вычисления суммы: S = 2 + 4 + 6 + 8 + ... ,
# содержащей N первых членов (N - натуральное число, N < 30, S - цело

def sum_even_recursive(n):
    """
    Рекурсивная функция для вычисления суммы N первых чётных чисел.
    S = 2 + 4 + 6 + 8 + ... + 2N
    """
    if n == 1:
        return 2
    return 2 * n + sum_even_recursive(n - 1)


def get_valid():
    """Функция для получения корректного ввода от пользователя."""
    while True:
        try:
            integer = input("Введите N: ")
            integer = int(integer)

            if 0 < integer < 30:
                return integer
            else:
                print("Ошибка: 0 < N < 30. Попробуйте ещё раз.")
        except ValueError:
            print("Ошибка: Введите целое число!!! Попробуйте ещё раз.")


valid_integer = get_valid()
result = sum_even_recursive(valid_integer)
print("Сумма первых",valid_integer," членов ряда = ", result)
